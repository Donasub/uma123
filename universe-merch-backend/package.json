{
  "name": "universe-merch-backend",
  "version": "1.0.0",
  "description": "Production-ready Node.js + PostgreSQL backend for Universe Merch Africa campus merchandise marketplace",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:schema": "node scripts/setup-db.js schema",
    "db:seed": "node scripts/setup-db.js seed",
    "db:reset": "npm run db:schema && npm run db:seed"
  },
  "keywords": [
    "merchandise",
    "ecommerce",
    "university",
    "campus",
    "africa",
    "nodejs",
    "postgresql"
  ],
  "author": "Universe Merch Africa",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.7",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.10.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7"
  }
}
