# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/universe_merch
PGSSLMODE=disable

# JWT
JWT_SECRET=your_super_secret_jwt_key_32_chars_minimum_please
JWT_EXPIRE=7d

# Email (Gmail with App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=noreply@universemerch.africa

# Payment Gateway (Paystack)
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Server
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000,https://universemerch.vercel.app
